# Slytherin Classroom — Environment Variables
# ─────────────────────────────────────────────
# 1. Copy this file and rename it to .env
# 2. Fill in your actual Supabase values
# 3. NEVER commit .env to GitHub!

# Supabase (get these from your Supabase project settings)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic (for the WHY? AI button — keep this SERVER-SIDE only)
# This goes in Vercel environment variables, NOT here
# ANTHROPIC_API_KEY=your-anthropic-key-here
